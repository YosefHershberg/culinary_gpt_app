FROM node:22-alpine

WORKDIR /app

# pnpm is enforced via the preinstall hook in package.json
RUN corepack enable && corepack prepare pnpm@latest --activate

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

COPY . .

EXPOSE 5173

# Bypass `pnpm run` so the --host flag actually reaches Vite
CMD ["pnpm", "exec", "vite", "--host", "0.0.0.0"]
